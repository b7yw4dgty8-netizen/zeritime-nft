# Скопируй этот файл: cp .env.example .env
# Затем заполни значения ниже

# Токен бота от @BotFather
BOT_TOKEN=твой_токен_сюда

# Твой Telegram ID (админ) — узнаешь у @userinfobot
ADMIN_TELEGRAM_ID=твой_telegram_id

# Порт сервера (локально)
PORT=3000

# URL Mini App (локально или после деплоя)
# Пример: https://zeritime-nft.onrender.com
MINI_APP_URL=http://localhost:3000

# PostgreSQL (только на Render — подставляется автоматически)
# Локально не нужно — используется SQLite в папке data/
# DATABASE_URL=postgres://user:pass@host/dbname
